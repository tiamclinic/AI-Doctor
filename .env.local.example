# Copy to .env.local and fill in values. Never commit .env.local.
# 本番（Firebase App Hosting）では apphosting.yaml + Secret Manager で注入される。

# OpenAI — server only (Route Handlers). Never expose to the client bundle.
OPENAI_API_KEY=
# 組織を切り替えて使う場合のみ設定（任意）。
OPENAI_ORG_ID=

# Public site URL (OGP, share links).
#   - local dev: http://localhost:3000
#   - prod    : https://<backend-id>--<branch>.<region>.hosted.app など、
#               App Hosting backend 作成後に確定する URL を設定する。
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Firebase Web（Analytics / 管理画面ログイン T-14）
# Firebase Console > プロジェクトの設定 > マイアプリ > Web アプリ からコピー。
# 管理画面（/admin/login）では API_KEY / AUTH_DOMAIN / PROJECT_ID / APP_ID が必須。
# Authentication で「メール/パスワード」を有効化し、ユーザ作成後 `npm run grant:admin -- <uid>`。
# NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID は Analytics の G- から始まる ID（任意）。
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET は未作成なら `PROJECT_ID.appspot.com` で可。
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=
# NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# --- Firestore / Admin SDK（サーバー専用）
# App Hosting 本番では Application Default Credentials（ADC）が使えるため、
# 多くの場合 FIREBASE_PROJECT_ID のみで可。
FIREBASE_PROJECT_ID=ai-doctor-5681b

# ローカル開発（どちらか一方）:
#
# A) 組織ポリシーで「秘密鍵の生成」が禁止されている場合（よくある）:
#    ターミナルで一度だけ実行し、自分の Google アカウントで ADC を入れる。
#      gcloud auth application-default login --project ai-doctor-5681b
#    FIREBASE_SERVICE_ACCOUNT_KEY は不要。dev サーバー再起動後に診断・管理画面を試す。
#
# B) 秘密鍵 JSON をダウンロードできる場合のみ:
#    Firebase Console > サービスアカウント > 新しい秘密鍵 → 1 行 JSON
# FIREBASE_SERVICE_ACCOUNT_KEY=
