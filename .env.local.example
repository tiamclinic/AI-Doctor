# Copy to .env.local and fill in values. Never commit .env.local.
# 本番（Firebase App Hosting）では apphosting.yaml + Secret Manager で注入される。

# OpenAI — server only (Route Handlers). Never expose to the client bundle.
OPENAI_API_KEY=
# 組織を切り替えて使う場合のみ設定（任意）。
OPENAI_ORG_ID=

# Public site URL (OGP, share links).
#   - local dev: http://localhost:3000
#   - prod    : https://<backend-id>--<branch>.<region>.hosted.app など、
#               App Hosting backend 作成後に確定する URL を設定する。
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Firebase Web（Analytics 用・すべて任意。未設定なら計測は送出されない）
# Firebase Console > プロジェクトの設定 > マイアプリ > Web アプリ からコピー。
# NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID は Analytics の G- から始まる ID。
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET は未作成なら `PROJECT_ID.appspot.com` で可。
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=
# NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
