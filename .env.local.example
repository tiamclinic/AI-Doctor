# Copy to .env.local and fill in values. Never commit .env.local.
# 本番（Firebase App Hosting）では apphosting.yaml + Secret Manager で注入される。

# OpenAI — server only (Route Handlers). Never expose to the client bundle.
OPENAI_API_KEY=
# 組織を切り替えて使う場合のみ設定（任意）。
OPENAI_ORG_ID=

# Public site URL (OGP, share links).
#   - local dev: http://localhost:3000
#   - prod    : https://<backend-id>--<branch>.<region>.hosted.app など、
#               App Hosting backend 作成後に確定する URL を設定する。
NEXT_PUBLIC_APP_URL=http://localhost:3000
